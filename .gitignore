# Root level gitignore for venture project

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
*.log
logs/

# Environment and credentials
.env
.env.local
.env.production
.env.staging
*.pem
*.key
*.crt

# Temporary files
*.tmp
*.temp
.cache/

# Build artifacts (will be handled by individual project gitignores)
dist/
build/
target/
node_modules/

# Database files
*.db
*.sqlite
*.sqlite3

# Backup files
*.bak
*.backup